---
import Layout from '../layouts/Layout.astro';
import { useTranslations, CONTACT_EMAIL, X_URL, X_HANDLE } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props {
  lang: Locale;
  title: string;
  description: string;
  screenshots?: string[];
}

const { lang, title, description, screenshots = [] } = Astro.props;
const t = useTranslations(lang);

const GITHUB_URL = 'https://github.com/tinyforgestore/vaultz';
const BUY_URL = '/l/vaultz';
const TRIAL_URL_MAC = 'https://github.com/tinyforgestore/vaultz/releases/latest/download/Vaultz_universal.dmg';
const TRIAL_URL_WINDOWS = 'https://github.com/tinyforgestore/vaultz/releases/latest/download/Vaultz_1.0.9_x64_en-US.msi';
const TRIAL_URL_LINUX = 'https://github.com/tinyforgestore/vaultz/releases/latest/download/Vaultz_amd64.AppImage';
const TRIAL_URL_FALLBACK = 'https://github.com/tinyforgestore/vaultz/releases/latest';
---

<Layout {title} {description} {lang}>
  <!-- ── Header ───────────────────────────────────────────── -->
  <header class="site-header">
    <div class="container">
      <a href={t('nav.home.href')} class="wordmark" aria-label="TinyForge home">
        <img src="/logo.png" alt="TinyForge logo" width="24" height="24" />
        <span class="wordmark-text">TinyForge</span>
      </a>
      <nav aria-label="Language">
        <ul class="site-nav">
          <li><a href={t('vaultz.nav.lang.href')} class="lang-toggle">{t('nav.lang')}</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <h1 class="hero-headline">{t('vaultz.hero.headline')}</h1>
          <p class="hero-subheadline">{t('vaultz.hero.subheadline')}</p>
          <div class="hero-actions">
            <a
              href={TRIAL_URL_FALLBACK}
              class="btn btn-primary"
              data-download-btn
              data-label-mac={t('vaultz.download.mac')}
              data-label-windows={t('vaultz.download.windows')}
              data-label-linux={t('vaultz.download.linux')}
              data-label-fallback={t('vaultz.hero.cta.trial')}
            >{t('vaultz.hero.cta.trial')}</a>
            <a href={BUY_URL} class="btn btn-secondary">{t('vaultz.hero.cta.buy')}</a>
          </div>
          <div class="platform-note-group">
            <p class="platform-note" data-os-note="mac" hidden>
              {t('vaultz.download.note.mac.before')}<a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>{t('vaultz.download.note.mac.middle')}<a href={TRIAL_URL_LINUX} class="platform-link">Linux</a>{t('vaultz.download.note.mac.after')}
            </p>
            <p class="platform-note" data-os-note="windows" hidden>
              {t('vaultz.download.note.windows.before')}<a href={TRIAL_URL_MAC} class="platform-link">macOS</a>{t('vaultz.download.note.windows.middle')}<a href={TRIAL_URL_LINUX} class="platform-link">Linux</a>{t('vaultz.download.note.windows.after')}
            </p>
            <p class="platform-note" data-os-note="linux" hidden>
              {t('vaultz.download.note.linux.before')}<a href={TRIAL_URL_MAC} class="platform-link">macOS</a>{t('vaultz.download.note.linux.middle')}<a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>{t('vaultz.download.note.linux.after')}
            </p>
            <p class="platform-note" data-os-note="fallback">
              {t('vaultz.download.note.fallback.before')}<a href={TRIAL_URL_MAC} class="platform-link">macOS</a>{t('vaultz.download.note.fallback.middle')}<a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>{t('vaultz.download.note.fallback.after')}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Screenshots ──────────────────────────────────────── -->
    {screenshots.length > 0 && (
      <section class="screenshots-section">
        <div class="container">
          <h2 class="screenshots-title">{t('vaultz.screenshots.title')}</h2>
          <div class="screenshots-strip">
            <div class="screenshot-item screenshot-item--side">
              <div class="screenshot-frame">
                <img src={screenshots[0]} alt="Vaultz onboarding screen" loading="lazy" />
              </div>
              <p class="screenshot-caption">{t('vaultz.screenshots.caption.1')}</p>
            </div>
            <div class="screenshot-item screenshot-item--center">
              <div class="screenshot-frame">
                <img src={screenshots[1]} alt="Vaultz vault list" loading="lazy" />
              </div>
              <p class="screenshot-caption">{t('vaultz.screenshots.caption.2')}</p>
            </div>
            <div class="screenshot-item screenshot-item--side">
              <div class="screenshot-frame">
                <img src={screenshots[2]} alt="Vaultz settings screen" loading="lazy" />
              </div>
              <p class="screenshot-caption">{t('vaultz.screenshots.caption.3')}</p>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- ── Why Vaultz ────────────────────────────────────────── -->
    <section class="why-section">
      <div class="container">
        <h2 class="section-title">{t('vaultz.why.title')}</h2>
        <ul class="why-grid">
          <li class="why-card">
            <div class="why-icon" aria-hidden="true">
              <!-- Shield icon -->
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 2L3 5v5c0 4.418 3.134 7.653 7 8.5C16.866 17.653 20 14.418 20 10V5l-7-3H10z" transform="translate(-1, 0)"/>
              </svg>
            </div>
            <p class="why-label">{t('vaultz.why.1.label')}</p>
            <p class="why-body">{t('vaultz.why.1.body')}</p>
          </li>
          <li class="why-card">
            <div class="why-icon" aria-hidden="true">
              <!-- Tag icon -->
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3h6l8 8a2 2 0 010 2.828l-3.172 3.172a2 2 0 01-2.828 0L3 9V3z"/>
                <circle cx="7" cy="7" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </div>
            <p class="why-label">{t('vaultz.why.2.label')}</p>
            <p class="why-body">{t('vaultz.why.2.body')}</p>
          </li>
          <li class="why-card">
            <div class="why-icon" aria-hidden="true">
              <!-- Hard drive icon -->
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="6" width="16" height="8" rx="2"/>
                <path d="M6 14v2M14 14v2"/>
                <circle cx="14" cy="10" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </div>
            <p class="why-label">{t('vaultz.why.3.label')}</p>
            <p class="why-body">{t('vaultz.why.3.body')}</p>
          </li>
          <li class="why-card">
            <div class="why-icon" aria-hidden="true">
              <!-- Monitor + laptop icon -->
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="12" height="9" rx="1.5"/>
                <path d="M6 12v2H2v1h10v-1H8v-2"/>
                <rect x="12" y="9" width="6" height="5" rx="1"/>
                <path d="M12 14h6"/>
              </svg>
            </div>
            <p class="why-label">{t('vaultz.why.4.label')}</p>
            <p class="why-body">{t('vaultz.why.4.body')}</p>
          </li>
          <li class="why-card">
            <div class="why-icon" aria-hidden="true">
              <!-- Lock icon -->
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="9" width="12" height="9" rx="1.5"/>
                <path d="M7 9V6a3 3 0 016 0v3"/>
              </svg>
            </div>
            <p class="why-label">{t('vaultz.why.5.label')}</p>
            <p class="why-body">{t('vaultz.why.5.body')}</p>
          </li>
          <li class="why-card">
            <div class="why-icon" aria-hidden="true">
              <!-- Code brackets icon -->
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 6L3 10l4 4M13 6l4 4-4 4"/>
              </svg>
            </div>
            <p class="why-label">{t('vaultz.why.6.label')}</p>
            <p class="why-body">{t('vaultz.why.6.body')}</p>
          </li>
        </ul>
      </div>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────────── -->
    <section class="faq-section">
      <div class="container">
        <h2 class="section-title">{t('vaultz.faq.title')}</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary class="faq-question">{t('vaultz.faq.1.q')}</summary>
            <p class="faq-answer">{t('vaultz.faq.1.a')}</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">{t('vaultz.faq.2.q')}</summary>
            <p class="faq-answer">{t('vaultz.faq.2.a')}</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">{t('vaultz.faq.3.q')}</summary>
            <p class="faq-answer">{t('vaultz.faq.3.a')}</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">{t('vaultz.faq.4.q')}</summary>
            <p class="faq-answer">{t('vaultz.faq.4.a.before')}<a href={GITHUB_URL} class="platform-link" target="_blank" rel="noopener noreferrer">GitHub</a>{t('vaultz.faq.4.a.after')}</p>
          </details>
        </div>
      </div>
    </section>
  </main>

  <!-- ── Closing CTA ──────────────────────────────────────── -->
  <section class="closing-cta">
    <div class="container">
      <h2 class="closing-cta-heading">{t('vaultz.cta.heading')}</h2>
      <div class="hero-actions">
        <a
          href={TRIAL_URL_FALLBACK}
          class="btn btn-primary"
          data-download-btn
          data-label-mac={t('vaultz.download.mac')}
          data-label-windows={t('vaultz.download.windows')}
          data-label-linux={t('vaultz.download.linux')}
          data-label-fallback={t('vaultz.hero.cta.trial')}
        >{t('vaultz.hero.cta.trial')}</a>
        <a href={BUY_URL} class="btn btn-secondary">{t('vaultz.hero.cta.buy')}</a>
      </div>
      <div class="platform-note-group">
        <p class="platform-note" data-os-note="mac" hidden>
          {t('vaultz.download.note.mac.before')}<a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>{t('vaultz.download.note.mac.middle')}<a href={TRIAL_URL_LINUX} class="platform-link">Linux</a>{t('vaultz.download.note.mac.after')}
        </p>
        <p class="platform-note" data-os-note="windows" hidden>
          {t('vaultz.download.note.windows.before')}<a href={TRIAL_URL_MAC} class="platform-link">macOS</a>{t('vaultz.download.note.windows.middle')}<a href={TRIAL_URL_LINUX} class="platform-link">Linux</a>{t('vaultz.download.note.windows.after')}
        </p>
        <p class="platform-note" data-os-note="linux" hidden>
          {t('vaultz.download.note.linux.before')}<a href={TRIAL_URL_MAC} class="platform-link">macOS</a>{t('vaultz.download.note.linux.middle')}<a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>{t('vaultz.download.note.linux.after')}
        </p>
        <p class="platform-note" data-os-note="fallback">
          {t('vaultz.download.note.fallback.before')}<a href={TRIAL_URL_MAC} class="platform-link">macOS</a>{t('vaultz.download.note.fallback.middle')}<a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>{t('vaultz.download.note.fallback.after')}
        </p>
      </div>
    </div>
  </section>

  <!-- ── Footer ───────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="container">
      <span>{t('vaultz.footer.brand')}</span>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href={X_URL} target="_blank" rel="noopener noreferrer">{X_HANDLE}</a>
    </div>
  </footer>
</Layout>

<style>
  /* ─── Hero ──────────────────────────────────────────────── */
  .hero {
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
    padding-block: clamp(4rem, 10vw, 7rem);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 640px;
  }

  .hero-headline {
    font-family: var(--font-mono);
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--color-text);
  }

  .hero-subheadline {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* ─── Platform Note ─────────────────────────────────────── */
  .platform-note-group {
    margin-top: 0.25rem;
  }

  [data-os-note][hidden] {
    display: none;
  }

  .platform-note {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .platform-link {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }

  .platform-link:hover {
    color: var(--color-text);
  }

  /* ─── Screenshots ──────────────────────────────────────── */
  .screenshots-section {
    padding-block: clamp(3rem, 7vw, 5rem);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .screenshots-title {
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 2.5rem;
    line-height: 1.2;
  }

  .screenshots-strip {
    display: grid;
    grid-template-columns: 0.78fr 1fr 0.78fr;
    align-items: center;
  }

  .screenshot-item {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .screenshot-item--side:first-child {
    transform: translateX(2rem);
    z-index: 1;
    position: relative;
  }

  .screenshot-item--side:last-child {
    transform: translateX(-2rem);
    z-index: 1;
    position: relative;
  }

  .screenshot-item--center {
    z-index: 2;
    position: relative;
  }

  .screenshot-frame {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background-color: var(--color-bg-card);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
  }

  .screenshot-item--side .screenshot-frame {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
    opacity: 0.85;
  }

  .screenshot-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .screenshot-caption {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-align: center;
  }

  .screenshot-item--side .screenshot-caption {
    opacity: 0.7;
  }

  /* ─── Shared Section Styles ─────────────────────────────── */
  .why-section,
  .faq-section {
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .faq-section {
    border-top: 1px solid var(--color-border);
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  /* ─── Why Grid ──────────────────────────────────────────── */
  .why-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    background-color: var(--color-border);
  }

  .why-card {
    background-color: var(--color-bg-card);
    padding: clamp(1.5rem, 4vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .why-icon {
    color: var(--color-accent);
    display: flex;
  }

  .why-label {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .why-body {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  /* ─── FAQ Accordion ─────────────────────────────────────── */
  .faq-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg-card);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    gap: 1rem;
    transition: color 0.15s ease;
    user-select: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .faq-item[open] .faq-question::after {
    content: '−';
  }

  .faq-question:hover {
    color: var(--color-accent);
  }

  .faq-answer {
    padding: 0 1.5rem 1.25rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* ─── Closing CTA ───────────────────────────────────────── */
  .closing-cta {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-top: 1px solid var(--color-border);
  }

  .closing-cta-heading {
    font-family: var(--font-mono);
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.3;
    max-width: 520px;
    margin-bottom: 1.75rem;
  }

  /* ─── Responsive ─────────────────────────────────────────── */
  @media (max-width: 600px) {
    .screenshots-strip {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .screenshot-item--side:first-child,
    .screenshot-item--side:last-child {
      transform: none;
      opacity: 1;
    }

    .screenshot-item--side .screenshot-frame {
      opacity: 1;
    }

    .screenshot-item--side .screenshot-caption {
      opacity: 1;
    }

    .closing-cta-heading {
      font-size: 1.125rem;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script define:vars={{
  labelMac: t('vaultz.download.mac'),
  labelWindows: t('vaultz.download.windows'),
  labelLinux: t('vaultz.download.linux'),
  labelFallback: t('vaultz.hero.cta.trial'),
  trialUrlMac: TRIAL_URL_MAC,
  trialUrlWindows: TRIAL_URL_WINDOWS,
  trialUrlLinux: TRIAL_URL_LINUX,
}}>
  (function () {
    var ua = navigator.userAgent;
    var isMac = /Macintosh|Mac OS X/.test(ua) && !/iPhone|iPad/.test(ua);
    var isWindows = /Windows NT/.test(ua);
    var isLinux = /Linux/.test(ua) && !/Android/.test(ua);
    var os = isMac ? 'mac' : isLinux ? 'linux' : 'fallback';

    if (os === 'fallback') return;

    var labels = { mac: labelMac, windows: labelWindows, linux: labelLinux };
    var hrefs = { mac: trialUrlMac, windows: trialUrlWindows, linux: trialUrlLinux };

    // Update all download buttons
    document.querySelectorAll('[data-download-btn]').forEach(function (btn) {
      btn.textContent = labels[os];
      btn.href = hrefs[os];
    });

    // Swap platform notes
    document.querySelectorAll('[data-os-note="fallback"]').forEach(function (el) {
      el.hidden = true;
    });
    document.querySelectorAll('[data-os-note="' + os + '"]').forEach(function (el) {
      el.hidden = false;
    });
  })();
</script>
