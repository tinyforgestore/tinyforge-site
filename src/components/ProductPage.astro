<script define:vars={{
  hasMacos,
  hasWindows,
  hasLinux,
  macUrl,
  windowsUrl,
  linuxUrl,
  downloadMacLabel,
  downloadWindowsLabel,
  downloadLinuxLabel,
  trialLabel,
}}>
  (function () {
    var ua = navigator.userAgent;
    var isMac = /Macintosh|Mac OS X/.test(ua) && !/iPhone|iPad/.test(ua);
    var isWindows = /Windows NT/.test(ua);
    var isLinux = /Linux/.test(ua) && !/Android/.test(ua);

    var os = isMac ? 'macos' : isWindows ? 'windows' : isLinux ? 'linux' : 'other';

    // If only mac+windows (no linux), treat linux as 'other'
    if (os === 'linux' && !hasLinux) os = 'other';

    var labels = { macos: downloadMacLabel, windows: downloadWindowsLabel, linux: downloadLinuxLabel };
    var hrefs = { macos: macUrl, windows: windowsUrl, linux: linuxUrl };

    if (os !== 'other' && os !== 'fallback') {
      document.querySelectorAll('[data-download-btn]').forEach(function (btn) {
        btn.textContent = labels[os];
        btn.href = hrefs[os];
      });

      // Hide fallback/other notes, show platform-specific note
      document.querySelectorAll('[data-os-note="other"],[data-os-note="fallback"]').forEach(function (el) {
        el.hidden = true;
      });
      document.querySelectorAll('[data-os-note="' + os + '"]').forEach(function (el) {
        el.hidden = false;
      });
    }
  })();
</script>

<script>
  document.querySelectorAll('.tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(function (b) {
        b.classList.remove('tab-btn--active');
        b.setAttribute('aria-selected', 'false');
      });
      document.querySelectorAll('.tab-panel').forEach(function (p) {
        (p as HTMLElement).hidden = true;
      });
      btn.classList.add('tab-btn--active');
      btn.setAttribute('aria-selected', 'true');
      var panel = document.querySelector('[data-panel="' + tab + '"]') as HTMLElement | null;
      if (panel) panel.hidden = false;
    });
  });
</script>
