---
import Layout from '../layouts/Layout.astro';
import { useTranslations, CONTACT_EMAIL, X_URL, X_HANDLE } from '../i18n/ui';
import type { Locale } from '../i18n/ui';
import type { Product } from '../types/product';
import productsData from '../data/products.json';

interface Props {
  lang: Locale;
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;
const t = useTranslations(lang);
const products = productsData as Product[];
---

<Layout {title} {description} {lang}>
  <header class="site-header">
    <div class="container">
      <a href={t('nav.home.href')} class="wordmark" aria-label="TinyForge home">
        <img src="/logo.png" alt="TinyForge logo" width="24" height="24" />
        <span class="wordmark-text">TinyForge</span>
      </a>
      <nav aria-label="Main navigation">
        <ul class="site-nav">
          <li><a href={t('nav.about.href')}>{t('nav.about')}</a></li>
          <li><a href={t('nav.lang.href')} class="lang-toggle">{t('nav.lang')}</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero" aria-labelledby="studio-name">
      <div class="container">
        <div class="hero-inner">
          <span class="hero-eyebrow">{t('hero.eyebrow')}</span>
          <h1 id="studio-name" class="studio-name">TinyForge</h1>
          <p class="hero-tagline">{t('hero.tagline')}</p>
        </div>
      </div>
    </section>

    <!-- Products / Coming Soon -->
    <section class="products-section">
      <div class="container">
        <h2 class="section-eyebrow">{t('products.eyebrow')}</h2>

        {products.length === 0 ? (
          <div class="coming-soon-card">
            <div class="coming-soon-inner">
              <span class="coming-soon-badge">{t('coming_soon.badge')}</span>
              <p class="coming-soon-heading">{t('coming_soon.heading')}</p>
              <p class="coming-soon-body">{t('coming_soon.body')}</p>
              <a href={t('nav.about.href')} class="btn btn-secondary">{t('coming_soon.cta')}</a>
            </div>
          </div>
        ) : (
          <ul class="product-grid">
            {products.map((product) => {
              const p = product as any;
              function lp(field: any): string {
                if (!field) return '';
                if (typeof field === 'string') return field;
                return field[lang] ?? field['en'] ?? '';
              }
              const productName = lp(p.meta?.title)?.split('—')[0]?.trim() || product.id;
              const tagline = lp(p.hero?.subhead) || lp(p.hero?.headline) || '';
              return (
                <li class="product-card">
                  {product.icon && (
                    <img src={product.icon} alt={productName} class="product-icon" />
                  )}
                  <div class="product-card-body">
                    <div class="product-card-header">
                      <span class="product-name">{productName}</span>
                    </div>
                    {tagline && <p class="product-tagline">{tagline}</p>}
                    <div class="product-meta">
                      {product.platforms.length > 0 && (
                        <span class="product-platforms">{product.platforms.join(' · ')}</span>
                      )}
                      {product.price && (
                        <span class="product-price">{product.price.currency} {product.price.amount}</span>
                      )}
                    </div>
                  </div>
                  {product.url && (
                    <a
                      href={product.url}
                      class="product-link btn btn-secondary"
                      aria-label={`Open ${productName}`}
                    >↗</a>
                  )}
                </li>
              );
            })}
          </ul>
        )}
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <span>{t('footer.copyright')}</span>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href={X_URL} target="_blank" rel="noopener noreferrer">{X_HANDLE}</a>
    </div>
  </footer>
</Layout>

<style>
  /* ─── Hero ──────────────────────────────────────────────── */
  .hero {
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 600px;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .studio-name {
    font-family: var(--font-mono);
    font-size: clamp(2.75rem, 7vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-text);
  }

  .hero-tagline {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 480px;
  }

  /* ─── Products Section ──────────────────────────────────── */
  .products-section {
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
  }

  .coming-soon-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-card);
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.75rem, 5vw, 3rem);
  }

  .coming-soon-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 480px;
  }

  .coming-soon-badge {
    display: inline-flex;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent-dim);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius);
  }

  .coming-soon-heading {
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.2;
  }

  .coming-soon-body {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ─── Product Grid ──────────────────────────────────────── */
  .product-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .product-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-card);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.15s ease;
  }

  .product-card:hover {
    border-color: var(--color-border-hover);
  }

  .product-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.5rem;
  }

  .product-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .product-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .product-name {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .product-tagline {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .product-meta {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
  }

  .product-platforms,
  .product-price {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  .product-link {
    align-self: flex-start;
  }

  @media (max-width: 600px) {
    .hero-inner {
      gap: 1.25rem;
    }

    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
