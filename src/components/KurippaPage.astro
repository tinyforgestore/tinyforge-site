---
import Layout from '../layouts/Layout.astro';
import { useTranslations, CONTACT_EMAIL, X_URL, X_HANDLE } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props {
  lang: Locale;
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;
const t = useTranslations(lang);

const BUY_URL = 'https://tinyforgestore.lemonsqueezy.com/checkout/buy/c4c7e746-ca85-492d-a4b9-cad7e749279f';
const TRIAL_URL_MAC = 'https://github.com/tinyforgestore/kurippa/releases/latest/download/Kurippa_universal.dmg';
const TRIAL_URL_WINDOWS = 'https://github.com/tinyforgestore/kurippa/releases/latest/download/kurippa_1.0.2_x64_en-US.msi';
const TRIAL_URL_FALLBACK = 'https://github.com/tinyforgestore/kurippa/releases/latest';
---

<Layout {title} {description} {lang}>
  <header class="site-header">
    <div class="container">
      <a href={t('nav.home.href')} class="wordmark" aria-label="TinyForge home">
        <img src="/logo.png" alt="TinyForge logo" width="24" height="24" />
        <span class="wordmark-text">TinyForge</span>
      </a>
      <nav aria-label="Language">
        <ul class="site-nav">
          <li><a href={t('kurippa.nav.lang.href')} class="lang-toggle">{t('nav.lang')}</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <h1 class="hero-headline">{t('kurippa.hero.headline')}</h1>
          <p class="hero-subheadline">{t('kurippa.hero.subheadline')}</p>
          <div class="hero-actions">
            <a
              href={TRIAL_URL_FALLBACK}
              class="btn btn-primary"
              data-download-btn
              data-label-mac={t('kurippa.download.mac')}
              data-label-windows={t('kurippa.download.windows')}
              data-label-fallback={t('kurippa.hero.cta.trial')}
            >{t('kurippa.hero.cta.trial')}</a>
            <a href={BUY_URL} class="btn btn-secondary">{t('kurippa.hero.cta.buy')}</a>
          </div>
          <div class="platform-note-group">
            <p class="platform-note" data-os-note="mac" hidden>
              Also available for <a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>
            </p>
            <p class="platform-note" data-os-note="windows" hidden>
              Also available for <a href={TRIAL_URL_MAC} class="platform-link">macOS</a>
            </p>
            <p class="platform-note" data-os-note="other">
              Available for <a href={TRIAL_URL_MAC} class="platform-link">macOS</a> and <a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="heroshot-section">
      <div class="container">
        <div class="heroshot-strip">
          <div class="heroshot-item heroshot-item--side">
            <div class="heroshot-frame">
              <img src="/screenshots/kurippa/3-clean.png" alt="Kurippa fuzzy search and URL preview" loading="lazy" />
            </div>
            <p class="heroshot-caption">{t('kurippa.heroshot.caption.left')}</p>
          </div>
          <div class="heroshot-item heroshot-item--center">
            <div class="heroshot-frame">
              <img src="/screenshots/kurippa/1-clean.png" alt="Kurippa clipboard history" loading="lazy" />
            </div>
            <p class="heroshot-caption">{t('kurippa.heroshot.caption.centre')}</p>
          </div>
          <div class="heroshot-item heroshot-item--side">
            <div class="heroshot-frame">
              <img src="/screenshots/kurippa/2-clean.png" alt="Kurippa colour preview" loading="lazy" />
            </div>
            <p class="heroshot-caption">{t('kurippa.heroshot.caption.right')}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="feature-section">
      <div class="container">
        <div class="feature-inner">
          <div class="feature-screenshot">
            <img src="/screenshots/kurippa/1-clean.png" alt="Kurippa clipboard history list" loading="lazy" />
          </div>
          <div class="feature-text">
            <span class="feature-eyebrow">History &amp; organisation</span>
            <h2 class="feature-headline">Everything you've copied, always within reach.</h2>
            <p class="feature-body">Kurippa stores your full clipboard history and keeps it organised. Pin what you reach for most. Group the rest into named folders. Access anything with a keyboard shortcut.</p>
            <ul class="feature-bullets">
              <li>Pinned items float to the top — ⌘0 to open</li>
              <li>Folders with ⌘1–⌘9 quick access</li>
              <li>Mixed content — text, code, images, colours</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="feature-section">
      <div class="container">
        <div class="feature-inner feature-inner--reverse">
          <div class="feature-screenshot">
            <img src="/screenshots/kurippa/3-clean.png" alt="Kurippa fuzzy search" loading="lazy" />
          </div>
          <div class="feature-text">
            <span class="feature-eyebrow">Fuzzy search</span>
            <h2 class="feature-headline">Find anything. Type anything.</h2>
            <p class="feature-body">Search across your entire clipboard history instantly. Type a fragment and Kurippa finds the match — across text, code, URLs and filenames. No need to remember exactly what you copied.</p>
            <ul class="feature-bullets">
              <li>Fuzzy matching — partial queries work</li>
              <li>Results update as you type</li>
              <li>⌘1–⌘9 to paste any result without lifting your hands</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="feature-section">
      <div class="container">
        <div class="feature-inner">
          <div class="feature-screenshot">
            <img src="/screenshots/kurippa/6-clean.png" alt="Kurippa paste as options" loading="lazy" />
          </div>
          <div class="feature-text">
            <span class="feature-eyebrow">Paste As</span>
            <h2 class="feature-headline">Paste smarter, not harder.</h2>
            <p class="feature-body">Every clipboard item can be pasted in the format you actually need — not just what you copied. Transform text on the way out without opening another tool.</p>
            <ul class="feature-bullets">
              <li>Plain text — strip all formatting</li>
              <li>Wrapped in code block — for Markdown and chat tools</li>
              <li>camelCase, snake_case, UPPERCASE, slug and more</li>
              <li>Wrap with custom delimiters</li>
              <li>Trim whitespace</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="feature-section">
      <div class="container">
        <div class="feature-inner feature-inner--reverse">
          <div class="feature-screenshot">
            <img src="/screenshots/kurippa/2-clean.png" alt="Kurippa colour preview" loading="lazy" />
          </div>
          <div class="feature-text">
            <span class="feature-eyebrow">Colour detection</span>
            <h2 class="feature-headline">Copy a colour. See it instantly.</h2>
            <p class="feature-body">Kurippa detects hex, RGB, HSL and Tailwind colour values and renders a live preview swatch — with all three format values shown. No more pasting a hex code into a colour picker just to see what it looks like.</p>
            <ul class="feature-bullets">
              <li>Detects #hex, rgb(), hsl(), and Tailwind classes</li>
              <li>Shows HEX, RGB and HSL side by side</li>
              <li>Inline colour dot in the list for every colour item</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="feature-section">
      <div class="container">
        <div class="feature-inner">
          <div class="feature-screenshot">
            <img src="/screenshots/kurippa/4-clean.png" alt="Kurippa QR code decode" loading="lazy" />
          </div>
          <div class="feature-text">
            <span class="feature-eyebrow">QR decode</span>
            <h2 class="feature-headline">Scanned a QR code? Paste the URL, not the image.</h2>
            <p class="feature-body">Copy a QR code image from anywhere and Kurippa decodes it automatically. Paste As gives you the URL directly — no scanner app, no extra steps.</p>
            <ul class="feature-bullets">
              <li>Auto-detects QR codes in copied images</li>
              <li>Paste as image or paste the decoded URL</li>
              <li>Works with any QR code — URLs, text, Wi-Fi credentials</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="feature-section">
      <div class="container">
        <div class="feature-inner feature-inner--reverse">
          <div class="feature-screenshot">
            <img src="/screenshots/kurippa/5-clean.png" alt="Kurippa keyboard-driven workflow" loading="lazy" />
          </div>
          <div class="feature-text">
            <span class="feature-eyebrow">Built for the keyboard</span>
            <h2 class="feature-headline">From hotkey to paste in under a second.</h2>
            <p class="feature-body">Kurippa is designed to stay out of your way. One global hotkey summons it from any app. One key pastes. It goes back to the background automatically — no clicks, no mode switching.</p>
            <ul class="feature-bullets">
              <li>Global hotkey — customisable</li>
              <li>⌘1–⌘9 instant paste from anywhere in the list</li>
              <li>Pastes into the previously active window automatically</li>
              <li>Sensitive items from password managers never recorded</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Setup ────────────────────────────────────────────── -->
    <section class="setup-section">
      <div class="container">
        <h2 class="section-title">Setup</h2>
        <div class="setup-tabs">
          <div class="tab-bar" role="tablist">
            <button class="tab-btn tab-btn--active" data-tab="mac" role="tab" aria-selected="true">macOS</button>
            <button class="tab-btn" data-tab="windows" role="tab" aria-selected="false">Windows</button>
          </div>

          <div class="tab-panel" data-panel="mac">
            <ol class="setup-steps">
              <li class="setup-step">
                <span class="setup-step-number">01</span>
                <div class="setup-step-content">
                  <p class="setup-step-title">Open the app (Gatekeeper bypass)</p>
                  <p class="setup-step-body">Right-click <code class="setup-code">Kurippa.app</code> → Open → click Open in the dialog. macOS blocks unsigned apps by default; this is a one-time step.</p>
                </div>
              </li>
              <li class="setup-step">
                <span class="setup-step-number">02</span>
                <div class="setup-step-content">
                  <p class="setup-step-title">Grant permissions (guided on first launch)</p>
                  <p class="setup-step-body">Kurippa will walk you through Accessibility and Input Monitoring on first launch. To re-enable manually if needed:</p>
                  <ul class="setup-step-bullets">
                    <li>System Preferences → Privacy &amp; Security → Accessibility → enable Kurippa</li>
                    <li>System Preferences → Privacy &amp; Security → Input Monitoring → enable Kurippa</li>
                  </ul>
                </div>
              </li>
              <li class="setup-step">
                <span class="setup-step-number">03</span>
                <div class="setup-step-content">
                  <p class="setup-step-title">Enable launch at login</p>
                  <p class="setup-step-body">System Preferences → General → Login Items → add Kurippa.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="tab-panel" data-panel="windows" hidden>
            <p class="setup-coming-soon">Windows setup guide coming soon.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <div class="container">
        <h2 class="section-title">{t('kurippa.faq.title')}</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary class="faq-question">{t('kurippa.faq.1.q')}</summary>
            <p class="faq-answer">{t('kurippa.faq.1.a')}</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">{t('kurippa.faq.2.q')}</summary>
            <p class="faq-answer">{t('kurippa.faq.2.a')}</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">{t('kurippa.faq.3.q')}</summary>
            <p class="faq-answer">{t('kurippa.faq.3.a')}</p>
          </details>
        </div>
      </div>
    </section>
  </main>

  <section class="closing-cta">
    <div class="container">
      <h2 class="closing-cta-heading">{t('kurippa.cta.heading')}</h2>
      <div class="hero-actions">
        <a
          href={TRIAL_URL_FALLBACK}
          class="btn btn-primary"
          data-download-btn
          data-label-mac={t('kurippa.download.mac')}
          data-label-windows={t('kurippa.download.windows')}
          data-label-fallback={t('kurippa.hero.cta.trial')}
        >{t('kurippa.hero.cta.trial')}</a>
        <a href={BUY_URL} class="btn btn-secondary">{t('kurippa.hero.cta.buy')}</a>
      </div>
      <div class="platform-note-group">
        <p class="platform-note" data-os-note="mac" hidden>
          Also available for <a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>
        </p>
        <p class="platform-note" data-os-note="windows" hidden>
          Also available for <a href={TRIAL_URL_MAC} class="platform-link">macOS</a>
        </p>
        <p class="platform-note" data-os-note="other">
          Available for <a href={TRIAL_URL_MAC} class="platform-link">macOS</a> and <a href={TRIAL_URL_WINDOWS} class="platform-link">Windows</a>
        </p>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container">
      <span>{t('kurippa.footer.brand')}</span>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href={X_URL} target="_blank" rel="noopener noreferrer">{X_HANDLE}</a>
    </div>
  </footer>
</Layout>

<style>
  .hero {
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
    padding-block: clamp(4rem, 10vw, 7rem);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 640px;
  }

  .hero-headline {
    font-family: var(--font-mono);
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--color-text);
  }

  .hero-subheadline {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .platform-note-group {
    margin-top: 0.25rem;
  }

  [data-os-note][hidden] {
    display: none;
  }

  .platform-note {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .platform-link {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }

  .platform-link:hover {
    color: var(--color-text);
  }

  .heroshot-section {
    padding-block: clamp(3rem, 7vw, 5rem);
    background:
      radial-gradient(ellipse 80% 70% at 15% 15%, rgba(216, 208, 245, 0.55) 0%, transparent 60%),
      radial-gradient(ellipse 70% 60% at 85% 85%, rgba(55, 138, 221, 0.10) 0%, transparent 55%),
      #EEEAF8;
    overflow: hidden;
  }

  .heroshot-strip {
    display: grid;
    grid-template-columns: 0.78fr 1fr 0.78fr;
    align-items: center;
    gap: 0;
  }

  .heroshot-item {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .heroshot-item--side:first-child {
    transform: translateX(2rem);
    z-index: 1;
    position: relative;
  }

  .heroshot-item--side:last-child {
    transform: translateX(-2rem);
    z-index: 1;
    position: relative;
  }

  .heroshot-item--center {
    z-index: 2;
    position: relative;
  }

  .heroshot-frame {
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(36, 18, 100, 0.22);
  }

  .heroshot-item--side .heroshot-frame {
    opacity: 0.85;
    box-shadow: 0 8px 24px rgba(36, 18, 100, 0.18);
  }

  .heroshot-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .heroshot-caption {
    font-family: var(--font-sans);
    font-style: italic;
    font-size: 0.8125rem;
    color: rgba(34, 16, 85, 0.7);
    text-align: center;
    line-height: 1.4;
  }

  .heroshot-item--side .heroshot-caption {
    opacity: 0.8;
  }

  .feature-section {
    padding-block: 7.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .feature-inner {
    display: flex;
    gap: clamp(3rem, 6vw, 5rem);
    align-items: center;
  }

  .feature-inner--reverse {
    flex-direction: row-reverse;
  }

  .feature-screenshot {
    flex: 0 0 520px;
    max-width: 520px;
  }

  .feature-screenshot img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .feature-text {
    flex: 1;
    max-width: 420px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .feature-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 400;
  }

  .feature-headline {
    font-family: var(--font-mono);
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--color-text);
  }

  .feature-body {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .feature-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature-bullets li {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    padding-left: 1.125rem;
    position: relative;
  }

  .feature-bullets li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 1rem;
    line-height: 1.6;
  }

  /* ─── Setup ─────────────────────────────────────────────── */
  .setup-section {
    padding-block: clamp(3rem, 7vw, 5rem);
    border-top: 1px solid var(--color-border);
  }

  .tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .tab-btn {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.625rem 1.25rem;
    cursor: pointer;
    margin-bottom: -1px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .tab-btn:hover {
    color: var(--color-text);
  }

  .tab-btn--active {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  .setup-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .setup-step {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    background-color: var(--color-bg-card);
    border-bottom: 1px solid var(--color-border);
  }

  .setup-step:last-child {
    border-bottom: none;
  }

  .setup-step-number {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    flex-shrink: 0;
    padding-top: 0.125rem;
    min-width: 1.75rem;
  }

  .setup-step-content {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .setup-step-title {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
  }

  .setup-step-body {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .setup-code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text);
    background-color: var(--color-bg-elevated);
    padding: 0.1em 0.35em;
    border-radius: 2px;
    border: 1px solid var(--color-border);
  }

  .setup-step-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .setup-step-bullets li {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    padding-left: 1.125rem;
    position: relative;
  }

  .setup-step-bullets li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 1rem;
    line-height: 1.6;
  }

  .setup-coming-soon {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    padding: 2rem 0;
  }

  /* ─── FAQ ───────────────────────────────────────────────── */
  .faq-section {
    padding-block: clamp(3rem, 7vw, 5rem);
    border-top: 1px solid var(--color-border);
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg-card);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    gap: 1rem;
    transition: color 0.15s ease;
    user-select: none;
