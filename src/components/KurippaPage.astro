</style>

<script define:vars={{
  labelMac: t('kurippa.download.mac'),
  labelWindows: t('kurippa.download.windows'),
  labelFallback: t('kurippa.hero.cta.trial'),
  trialUrlMac: TRIAL_URL_MAC,
  trialUrlWindows: TRIAL_URL_WINDOWS,
}}>
  (function () {
    var ua = navigator.userAgent;
    var isMac = /Macintosh|Mac OS X/.test(ua) && !/iPhone|iPad/.test(ua);
    var isWindows = /Windows NT/.test(ua);
    var os = isMac ? 'mac' : 'other';

    if (os === 'other') return;

    var labels = { mac: labelMac, windows: labelWindows };
    var hrefs = { mac: trialUrlMac, windows: trialUrlWindows };

    document.querySelectorAll('[data-download-btn]').forEach(function (btn) {
      btn.textContent = labels[os];
      btn.href = hrefs[os];
    });

    document.querySelectorAll('[data-os-note="other"]').forEach(function (el) {
      el.hidden = true;
    });
    document.querySelectorAll('[data-os-note="' + os + '"]').forEach(function (el) {
      el.hidden = false;
    });
  })();
</script>

<script>
  document.querySelectorAll('.tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var tab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(function (b) {
        b.classList.remove('tab-btn--active');
        b.setAttribute('aria-selected', 'false');
      });
      document.querySelectorAll('.tab-panel').forEach(function (p) {
        p.hidden = true;
      });
      btn.classList.add('tab-btn--active');
      btn.setAttribute('aria-selected', 'true');
      document.querySelector('[data-panel="' + tab + '"]').hidden = false;
    });
  });
</script>
