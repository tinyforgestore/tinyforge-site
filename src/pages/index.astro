---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="TinyForge — Small, focused desktop utilities"
  description="TinyForge is an independent software studio building small, focused desktop utilities. No subscriptions, no accounts — just software that works."
>
  <header class="site-header">
    <div class="container">
      <a href="/" class="wordmark" aria-label="TinyForge home">
        <img src="/logo.png" alt="TinyForge logo" />
        <span class="wordmark-text">TinyForge</span>
      </a>
      <nav aria-label="Main navigation">
        <ul class="site-nav">
          <li><a href="/about">About</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="hero" aria-labelledby="studio-name">
      <div class="container">
        <div class="hero-inner">
          <span class="hero-eyebrow">Independent software studio</span>
          <h1 id="studio-name" class="studio-name">TinyForge</h1>
          <p class="hero-tagline">
            Small, focused desktop utilities. No subscriptions, no cloud accounts — just software that works and stays yours.
          </p>
        </div>
      </div>
    </section>

    <!-- ── Coming Soon ───────────────────────────────────────── -->
    <section class="coming-soon-section" aria-labelledby="products-heading">
      <div class="container">
        <p id="products-heading" class="section-eyebrow">Products</p>

        <div class="coming-soon-card">
          <div class="coming-soon-inner">
            <span class="coming-soon-badge">Coming soon</span>
            <h2 class="coming-soon-heading">Something's being forged.</h2>
            <p class="coming-soon-body">
              We're working on a set of small, precise desktop tools. Built with care, priced fairly, yours forever.
            </p>
            <a href="/about" class="btn btn-secondary">Learn about the studio</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <span>&copy; 2026 TinyForge</span>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="mailto:hello@tinyforge.store">hello@tinyforge.store</a>
    </div>
  </footer>
</Layout>

<style>
  /* ─── Hero ──────────────────────────────────────────────── */
  .hero {
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 600px;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .studio-name {
    font-family: var(--font-mono);
    font-size: clamp(2.75rem, 7vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-text);
  }

  .hero-tagline {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 480px;
  }

  /* ─── Coming Soon ───────────────────────────────────────── */
  .coming-soon-section {
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
  }

  .coming-soon-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-card);
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.75rem, 5vw, 3rem);
  }

  .coming-soon-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 480px;
  }

  .coming-soon-badge {
    display: inline-flex;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent-dim);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius);
  }

  .coming-soon-heading {
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.2;
  }

  .coming-soon-body {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .hero-inner {
      gap: 1.25rem;
    }
  }
</style>
